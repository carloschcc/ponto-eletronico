# Troque pelo seu domínio real (o mesmo que você vai apontar via DNS para o IP
# deste servidor). Sem domínio, o Let's Encrypt não emite certificado — só
# funciona com nome, não com IP puro.
SEU_DOMINIO_AQUI.com.br {
    reverse_proxy app:80
}

